"use client";

import { useState } from "react";

const QUESTION_TYPES = [
  { type: "short_text", label: "Short Text", icon: "=", color: "bg-blue-100 text-blue-600" },
  { type: "email", label: "Email", icon: "✉", color: "bg-pink-100 text-pink-600" },
];

// coming-soon types, matching Typeform's picker for visual completeness
const DISABLED_TYPES = [
  { label: "Long Text", icon: "≡", color: "bg-blue-100 text-blue-600" },
  { label: "Multiple Choice", icon: "A-", color: "bg-purple-100 text-purple-600" },
  { label: "Dropdown", icon: "⌄", color: "bg-purple-100 text-purple-600" },
  { label: "Yes/No", icon: "⊘", color: "bg-purple-100 text-purple-600" },
  { label: "Rating", icon: "★", color: "bg-green-100 text-green-600" },
  { label: "Number", icon: "#", color: "bg-amber-100 text-amber-600" },
  { label: "Phone Number", icon: "📞" }, // Note: Country calling code selection would be implemented here
  { label: "Contact Info", icon: "👤" },
  { label: "Address", icon: "📍" },
  { label: "File Upload", icon: "📁" },
  { label: "Picture Choice", icon: "🖼" },
];

export default function QuestionTypeModal({
  onSelect,
  onClose,
}: {
  onSelect: (type: string) => void;
  onClose: () => void;
}) {
  const [search, setSearch] = useState("");

  const filtered = QUESTION_TYPES.filter((t) =>
    t.label.toLowerCase().includes(search.toLowerCase())
  );

  return (
    <div
      className="fixed inset-0 z-50 flex items-start justify-center bg-black/30 pt-24"
      onClick={onClose}
    >
      <div
        className="w-96 rounded-xl bg-white shadow-xl"
        onClick={(e) => e.stopPropagation()}
      >
        <div className="border-b p-3">
          <input
            autoFocus
            value={search}
            onChange={(e) => setSearch(e.target.value)}
            placeholder="Search form elements"
            className="w-full rounded-md bg-gray-100 px-3 py-2 text-sm outline-none"
          />
        </div>

        <div className="max-h-96 overflow-y-auto p-2">
          {filtered.map((t) => (
            <button
              key={t.type}
              onClick={() => onSelect(t.type)}
              className="flex w-full items-center gap-3 rounded-lg px-3 py-2 text-left text-sm hover:bg-gray-100"
            >
              <span
                className={`flex h-7 w-7 items-center justify-center rounded-md text-xs font-medium ${t.color}`}
              >
                {t.icon}
              </span>
              {t.label}
            </button>
          ))}

          {filtered.length > 0 && DISABLED_TYPES.length > 0 && (
            <div className="mt-2 border-t pt-2">
              {DISABLED_TYPES.map((t) => (
                <button
                  key={t.label}
                  onClick={() => alert("Coming soon!")}
                  className="flex w-full items-center gap-3 rounded-lg px-3 py-2 text-left text-sm text-gray-400 hover:bg-gray-50"
                >
                  <span className="flex h-7 w-7 items-center justify-center rounded-md bg-gray-100 text-xs">
                    {t.icon}
                  </span>
                  {t.label}
                </button>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}